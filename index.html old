<!DOCTYPE html>

<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>McGee Web Solutions — Websites, AI &amp; Review Systems</title>
<link rel="preconnect" href="https://fonts.googleapis.com/">
<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ── Tokens ─────────────────────────────────────── */
:root {
  --ink:         #0F1D30;
  --ink-80:      rgba(15,29,48,.8);
  --cream:       #F6F4EF;
  --cream-dark:  #EDEBE4;
  --slate:       #536275;
  --slate-lt:    #8293A6;
  --copper:      #B07535;
  --copper-deep: #8F5E28;
  --copper-pale: #F3E8D8;
  --hairline:    #D9D5C9;
  --white:       #FFFFFF;
  --gold:        #C9973F;

  --serif: "Source Serif 4", Georgia, serif;
  --sans:  "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
  --mono:  "IBM Plex Mono", monospace;

  --max: 1200px;
  --pad: clamp(24px, 5vw, 48px);
  --radius: 3px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--cream);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 16px;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Grain texture overlay */
body::after {
  content: '';
  position: fixed; inset: 0; z-index: 9999;
  pointer-events: none;
  opacity: .028;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 128px;
}

img { max-width: 100%; display: block; }
a   { color: var(--copper-deep); text-decoration: none; }

.wrap { max-width: var(--max); margin: 0 auto; padding: 0 var(--pad); }

h1, h2, h3 {
  font-family: var(--serif);
  color: var(--ink);
  font-weight: 800;
  letter-spacing: -0.025em;
  line-height: 1.08;
}
h1 { font-size: clamp(2.6rem, 5.5vw, 4.2rem); }
h2 { font-size: clamp(1.9rem, 3.4vw, 2.8rem); }
h3 { font-size: 1.3rem; font-weight: 700; letter-spacing: -0.015em; }
p  { color: var(--slate); }

.eyebrow {
  font-family: var(--mono);
  font-size: 0.76rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--copper-deep);
  margin-bottom: 16px;
  display: block;
}

a:focus-visible, button:focus-visible { outline: 2px solid var(--copper); outline-offset: 3px; }

@media (prefers-reduced-motion: reduce) { * { transition: none !important; animation: none !important; } }

/* ── Reveal ──────────────────────────────────────── */
.reveal { opacity: 0; transform: translateY(22px); transition: opacity .55s ease, transform .55s ease; }
.reveal.visible { opacity: 1; transform: none; }
.reveal-delay-1 { transition-delay: .1s; }
.reveal-delay-2 { transition-delay: .2s; }
.reveal-delay-3 { transition-delay: .3s; }

/* ── Buttons ─────────────────────────────────────── */
.btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 13px 26px; border-radius: var(--radius);
  font-family: var(--sans); font-weight: 600; font-size: 0.95rem;
  transition: background .15s, color .15s, transform .15s;
  cursor: pointer; border: none;
}
.btn:hover { transform: translateY(-1px); }
.btn-primary { background: var(--ink); color: var(--cream); }
.btn-primary:hover { background: var(--copper-deep); color: var(--cream); }
.btn-ghost { background: transparent; color: var(--ink); border: 1.5px solid var(--ink); }
.btn-ghost:hover { background: var(--ink); color: var(--cream); }
.btn-large { padding: 16px 36px; font-size: 1rem; }

/* ── Header ──────────────────────────────────────── */
.site-header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(246,244,239,.96);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--hairline);
  transition: box-shadow .25s;
}
.site-header::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--copper-deep), var(--gold), var(--copper-deep));
}
.site-header.scrolled { box-shadow: 0 4px 24px rgba(15,29,48,.09); }

.header-inner { display: flex; align-items: center; justify-content: space-between; height: 68px; }

.brand { display: flex; align-items: center; gap: 10px; color: var(--ink); flex-shrink: 0; }

.brand-mark {
  font-family: var(--mono); font-size: 0.76rem; letter-spacing: 0.06em;
  background: var(--ink); color: var(--cream); padding: 5px 8px; border-radius: 2px; font-weight: 500;
}
.brand-name { font-family: var(--serif); font-weight: 600; font-size: 1.08rem; color: var(--ink); }

.main-nav { display: flex; align-items: center; gap: 32px; }
.main-nav a { color: var(--ink); font-size: 0.92rem; font-weight: 500; transition: color .15s; }
.main-nav a:hover { color: var(--copper-deep); }
.nav-cta { background: var(--ink) !important; color: var(--cream) !important; padding: 9px 20px; border-radius: var(--radius); font-weight: 600 !important; }
.nav-cta:hover { background: var(--copper-deep) !important; color: var(--cream) !important; }

.hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 6px; background: none; border: none; }
.hamburger span { display: block; width: 22px; height: 2px; background: var(--ink); border-radius: 2px; transition: transform .25s, opacity .25s; }
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

.mobile-nav { display: none; flex-direction: column; background: var(--cream); border-bottom: 1px solid var(--hairline); padding: 12px var(--pad) 20px; }
.mobile-nav.open { display: flex; }
.mobile-nav a { color: var(--ink); font-size: 1rem; font-weight: 500; padding: 12px 0; border-bottom: 1px solid var(--hairline); }
.mobile-nav a:last-child { border-bottom: none; margin-top: 8px; }

/* ── Hero ────────────────────────────────────────── */
.hero { padding: 100px 0 92px; position: relative; overflow: hidden; }
.hero::before {
  content: ''; position: absolute; top: -200px; right: -140px;
  width: 640px; height: 640px; border-radius: 50%;
  background: radial-gradient(circle, rgba(176,117,53,.09) 0%, transparent 68%);
  pointer-events: none;
}
.hero::after {
  content: ''; position: absolute; bottom: -80px; left: -80px;
  width: 320px; height: 320px; border-radius: 50%;
  background: radial-gradient(circle, rgba(176,117,53,.05) 0%, transparent 70%);
  pointer-events: none;
}

.hero-inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 64px; align-items: center; }
.hero-copy > * + * { margin-top: 20px; }
.hero h1 { margin-top: 10px; }
.hero-lede { font-size: 1.08rem; line-height: 1.7; max-width: 480px; }

.hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 36px; align-items: center; }

.hero-instagram {
  display: flex; align-items: center; gap: 7px; margin-top: 16px;
  font-family: var(--mono); font-size: 0.78rem; color: var(--slate-lt);
  letter-spacing: 0.03em;
}
.hero-instagram a { color: var(--copper-deep); transition: color .15s; }
.hero-instagram a:hover { color: var(--ink); }
.hero-instagram svg { width: 13px; height: 13px; fill: var(--slate-lt); flex-shrink: 0; }

/* ── Browser Mockup ──────────────────────────────── */
.browser-mockup {
  border-radius: 8px; overflow: hidden;
  box-shadow: 0 20px 60px rgba(22,36,59,.14), 0 4px 16px rgba(22,36,59,.08);
  border: 1.5px solid var(--hairline);
  background: var(--white);
  position: relative; z-index: 1;
}

.browser-chrome {
  background: #EDEAE4; border-bottom: 1.5px solid var(--hairline);
  padding: 10px 14px; display: flex; align-items: center; gap: 10px;
}
.browser-dots { display: flex; gap: 5px; flex-shrink: 0; }
.browser-dots span { width: 10px; height: 10px; border-radius: 50%; }
.browser-dots span:nth-child(1) { background: #FF5F57; }
.browser-dots span:nth-child(2) { background: #FEBC2E; }
.browser-dots span:nth-child(3) { background: #28C840; }

.browser-url {
  flex: 1; background: var(--white); border: 1px solid #D0CCBF;
  border-radius: 4px; padding: 4px 10px;
  font-family: var(--mono); font-size: 0.68rem; color: var(--slate-lt);
}

.browser-body { padding: 0; overflow: hidden; }

/* Mini website inside hero mockup */
.mock-site { background: #F8F7F3; }

.mock-nav {
  background: #16243B; padding: 10px 16px;
  display: flex; align-items: center; justify-content: space-between;
}
.mock-nav-brand { display: flex; gap: 6px; align-items: center; }
.mock-nav-brand .dot { width: 22px; height: 8px; background: #B5773C; border-radius: 2px; }
.mock-nav-brand .line { width: 48px; height: 6px; background: rgba(255,255,255,.3); border-radius: 2px; }
.mock-nav-links { display: flex; gap: 8px; }
.mock-nav-links span { width: 24px; height: 5px; background: rgba(255,255,255,.2); border-radius: 2px; }
.mock-nav-btn { width: 40px; height: 18px; background: #B5773C; border-radius: 2px; }

.mock-hero-block { padding: 20px 16px 18px; }
.mock-hero-label { width: 60px; height: 5px; background: #B5773C; border-radius: 2px; margin-bottom: 10px; opacity: .6; }
.mock-hero-h1 { width: 85%; height: 10px; background: #16243B; border-radius: 2px; margin-bottom: 6px; }
.mock-hero-h2 { width: 65%; height: 10px; background: #16243B; border-radius: 2px; margin-bottom: 10px; }
.mock-hero-p { width: 90%; height: 5px; background: #D0CCBF; border-radius: 2px; margin-bottom: 4px; }
.mock-hero-p.short { width: 70%; }
.mock-hero-btns { display: flex; gap: 6px; margin-top: 12px; }
.mock-hero-btns span:nth-child(1) { width: 60px; height: 18px; background: #16243B; border-radius: 2px; }
.mock-hero-btns span:nth-child(2) { width: 60px; height: 18px; background: transparent; border: 1.5px solid #16243B; border-radius: 2px; }

.mock-divider { height: 1px; background: #DDD8CC; margin: 0 16px; }

.mock-cards-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; padding: 14px 16px 18px; }
.mock-card-block { background: var(--white); border: 1px solid #E8E4DC; border-radius: 3px; padding: 10px; }
.mock-card-thumb { height: 32px; border-radius: 2px; margin-bottom: 7px; }
.mock-card-block:nth-child(1) .mock-card-thumb { background: linear-gradient(135deg, #EEF2F8, #C8D8EE); }
.mock-card-block:nth-child(2) .mock-card-thumb { background: linear-gradient(135deg, #F5EDE0, #E8D0B0); }
.mock-card-block:nth-child(3) .mock-card-thumb { background: linear-gradient(135deg, #EDF2EE, #C0D8C2); }
.mock-card-line { height: 5px; background: #D0CCBF; border-radius: 2px; margin-bottom: 4px; }
.mock-card-line.short { width: 60%; }

/* ── Trust strip ─────────────────────────────────── */
.trust-strip { border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); background: var(--white); position: relative; }

.trust-inner { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; align-items: stretch; }

.trust-lede { padding: 28px 40px 28px 0; border-right: 1px solid var(--hairline); }
.trust-lede p { font-size: 0.92rem; color: var(--slate); line-height: 1.5; }

.trust-stat { padding: 24px 28px; border-right: 1px solid var(--hairline); display: flex; flex-direction: column; justify-content: center; }
.trust-stat:last-child { border-right: none; }
.trust-stat strong { font-family: var(--serif); font-size: 2rem; font-weight: 700; color: var(--ink); display: block; line-height: 1; }
.trust-stat span { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--slate-lt); margin-top: 5px; display: block; }

/* ── Practice / Ledger ───────────────────────────── */
.practice { padding: 112px 0; }

.practice-header { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: end; margin-bottom: 64px; }
.practice-header h2 { margin: 0; }
.practice-header p { font-size: 1rem; line-height: 1.75; }

.ledger { border-top: 1.5px solid var(--ink); }

.ledger-row {
  display: grid; grid-template-columns: 280px 1fr; gap: 56px;
  padding: 52px 0; border-bottom: 1px solid var(--hairline);
  transition: background .2s, padding .2s;
  position: relative;
}
.ledger-row::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0;
  width: 2px; background: transparent;
  transition: background .2s;
}
.ledger-row:hover { background: rgba(176,117,53,.025); padding-left: 16px; padding-right: 16px; margin: 0 -16px; }
.ledger-row:hover::before { background: var(--copper); }

.ledger-tag { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.1em; color: var(--copper-deep); display: block; margin-bottom: 12px; }
.ledger-label h3 { font-size: 1.4rem; font-weight: 700; line-height: 1.2; letter-spacing: -0.015em; }
.ledger-body p { max-width: 580px; font-size: 0.98rem; line-height: 1.8; }

.ledger-meta { list-style: none; margin: 22px 0 0; padding: 0; display: flex; flex-direction: column; }
.ledger-meta li {
  font-family: var(--mono); font-size: 0.79rem; color: var(--slate);
  padding: 8px 0; border-bottom: 1px solid var(--hairline);
  display: flex; align-items: center; gap: 12px;
}
.ledger-meta li:last-child { border-bottom: none; }
.ledger-meta li::before { content: ''; display: inline-block; width: 18px; height: 1px; background: var(--copper); flex-shrink: 0; }

/* ── Plaque Mockup ───────────────────────────────── */
.plaque-mockup-wrap {
  margin-top: 28px;
  display: flex;
  gap: 16px;
  align-items: flex-start;
}

.plaque-mockup {
  width: 160px;
  flex-shrink: 0;
  background: linear-gradient(160deg, #1c2a3a, #0f1a28);
  border-radius: 8px;
  padding: 16px 14px;
  box-shadow: 0 8px 24px rgba(0,0,0,.25), inset 0 1px 0 rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.08);
  position: relative;
  overflow: hidden;
}
.plaque-mockup::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(201,151,63,.5), transparent);
}

.plaque-top { text-align: center; margin-bottom: 10px; }
.plaque-stars { color: var(--gold); font-size: 0.65rem; letter-spacing: 2px; display: block; margin-bottom: 5px; }
.plaque-brand { display: flex; align-items: center; justify-content: center; gap: 4px; margin-bottom: 3px; }
.plaque-brand-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--gold); opacity: .9; }
.plaque-brand-name { width: 52px; height: 5px; background: rgba(255,255,255,.5); border-radius: 1px; }
.plaque-tagline { width: 70px; height: 3px; background: rgba(255,255,255,.2); border-radius: 1px; margin: 0 auto; }

.plaque-divider { height: 1px; background: rgba(255,255,255,.08); margin: 10px 0; }

.plaque-cta { text-align: center; margin-bottom: 8px; }
.plaque-cta-text { font-family: var(--mono); font-size: 0.5rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,.45); display: block; margin-bottom: 6px; }

/* CSS QR code */
.plaque-qr {
  width: 56px; height: 56px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(7, 1fr); gap: 1.5px;
  padding: 5px; background: rgba(255,255,255,.9); border-radius: 3px;
}
.qr-cell { border-radius: 1px; background: transparent; }
.qr-cell.b { background: #0f1a28; }

.plaque-scan-label { font-family: var(--mono); font-size: 0.48rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); text-align: center; display: block; margin-top: 8px; opacity: .8; }

.plaque-caption { flex: 1; }
.plaque-caption p { font-size: 0.88rem; line-height: 1.65; margin-bottom: 10px; }
.plaque-caption strong { font-size: 0.82rem; font-family: var(--mono); color: var(--copper-deep); letter-spacing: 0.04em; }

/* ── Approach ────────────────────────────────────── */
.approach { background: var(--ink); padding: 112px 0; color: var(--cream); position: relative; overflow: hidden; }
.approach::after {
  content: ''; position: absolute; bottom: -120px; left: -80px;
  width: 500px; height: 500px; border-radius: 50%;
  background: radial-gradient(circle, rgba(176,117,53,.12) 0%, transparent 68%);
  pointer-events: none;
}
.approach::before {
  content: ''; position: absolute; top: -80px; right: -60px;
  width: 300px; height: 300px; border-radius: 50%;
  background: radial-gradient(circle, rgba(176,117,53,.06) 0%, transparent 70%);
  pointer-events: none;
}

.approach .eyebrow { color: var(--copper); }
.approach h2 { color: var(--cream); }

.approach-inner { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 72px; align-items: center; }

/* Automation flow diagram replaces the AI image */
.flow-diagram {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 8px;
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
  z-index: 1;
}

.flow-diagram-label {
  font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--copper); margin-bottom: 24px;
}

.flow-step {
  display: flex; align-items: flex-start; gap: 14px; position: relative;
}

.flow-step-icon {
  width: 38px; height: 38px; border-radius: 8px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem;
}
.flow-step-icon.blue  { background: rgba(66,133,244,.2); border: 1px solid rgba(66,133,244,.3); }
.flow-step-icon.copper { background: rgba(181,119,60,.2); border: 1px solid rgba(181,119,60,.3); }
.flow-step-icon.green  { background: rgba(52,211,153,.15); border: 1px solid rgba(52,211,153,.25); }
.flow-step-icon.purple { background: rgba(167,139,250,.15); border: 1px solid rgba(167,139,250,.25); }

.flow-step-body { flex: 1; padding-bottom: 28px; }
.flow-step:last-child .flow-step-body { padding-bottom: 0; }

.flow-step-name {
  font-family: var(--sans); font-size: 0.88rem; font-weight: 600;
  color: var(--cream); margin-bottom: 3px;
}

.flow-step-desc { font-size: 0.8rem; color: rgba(255,255,255,.45); line-height: 1.5; }

.flow-connector {
  width: 1px; background: rgba(255,255,255,.12); height: 100%;
  position: absolute; left: 18px; top: 38px; bottom: 0;
  z-index: 0;
}
.flow-step:last-child .flow-connector { display: none; }

.flow-step-line {
  position: absolute; left: 18px; top: 38px;
  width: 1px; height: calc(100% - 10px);
  background: linear-gradient(to bottom, rgba(181,119,60,.4), rgba(181,119,60,.1));
}
.flow-step:last-child .flow-step-line { display: none; }

.approach-copy > * + * { margin-top: 22px; }
.approach-copy p { color: #C0CAD7; font-size: 0.98rem; line-height: 1.75; }

.approach-list { margin-top: 36px; display: grid; gap: 0; }
.approach-item { padding: 22px 0; border-bottom: 1px solid rgba(255,255,255,.1); }
.approach-item:first-child { border-top: 1px solid rgba(255,255,255,.1); }
.approach-item dt { font-family: var(--serif); font-size: 1.1rem; font-weight: 600; color: var(--cream); margin-bottom: 6px; }
.approach-item dd { color: #A8B5C4; font-size: 0.93rem; line-height: 1.65; }

/* ── Selected work ───────────────────────────────── */
.work { padding: 112px 0; background: var(--cream-dark); }

.work-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 48px; flex-wrap: wrap; gap: 20px; }
.work-header h2 { margin: 0; }
.work-header a { font-family: var(--mono); font-size: 0.8rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--copper-deep); display: flex; align-items: center; gap: 6px; transition: gap .15s; }
.work-header a:hover { gap: 10px; }
.work-header a::after { content: '→'; }

.work-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

.work-card { border: 1px solid var(--hairline); border-radius: 6px; background: var(--white); overflow: hidden; transition: box-shadow .2s, transform .2s; }
.work-card:hover { box-shadow: 0 10px 32px rgba(22,36,59,.1); transform: translateY(-3px); }

/* Tiny browser previews inside work cards */
.work-preview {
  border-bottom: 1px solid var(--hairline);
  overflow: hidden;
}

.work-preview-chrome {
  background: #EDEAE4; padding: 7px 10px;
  display: flex; align-items: center; gap: 6px;
  border-bottom: 1px solid #D8D4CC;
}
.work-preview-dots { display: flex; gap: 3px; }
.work-preview-dots span { width: 7px; height: 7px; border-radius: 50%; }
.work-preview-dots span:nth-child(1) { background: #FF5F57; }
.work-preview-dots span:nth-child(2) { background: #FEBC2E; }
.work-preview-dots span:nth-child(3) { background: #28C840; }
