<!DOCTYPE html>

<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Get in Contact — McGee Web Solutions</title>
<link rel="preconnect" href="https://fonts.googleapis.com/">
<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ── Tokens ─────────────────────────────────────── */
:root {
  --ink:         #16243B;
  --cream:       #F7F5F0;
  --cream-dark:  #EFECE5;
  --slate:       #5B6B82;
  --slate-lt:    #8898AB;
  --copper:      #B5773C;
  --copper-deep: #94602F;
  --hairline:    #DDD8CC;
  --white:       #FFFFFF;

  --serif: "Source Serif 4", Georgia, serif;
  --sans:  "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
  --mono:  "IBM Plex Mono", monospace;

  --max: 1180px;
  --pad: clamp(20px, 5vw, 40px);
  --radius: 4px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--cream);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 16px;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
}

a { color: var(--copper-deep); text-decoration: none; }
img { max-width: 100%; display: block; }

.wrap { max-width: var(--max); margin: 0 auto; padding: 0 var(--pad); }

h1, h2, h3 {
  font-family: var(--serif);
  color: var(--ink);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.1;
}
h1 { font-size: clamp(2.2rem, 4.5vw, 3.2rem); }
h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); }
p  { color: var(--slate); }

.eyebrow {
  font-family: var(--mono);
  font-size: 0.76rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--copper-deep);
  margin-bottom: 14px;
  display: block;
}

a:focus-visible, button:focus-visible { outline: 2px solid var(--copper); outline-offset: 3px; }

@media (prefers-reduced-motion: reduce) { * { transition: none !important; } }

/* ── Reveal ──────────────────────────────────────── */
.reveal { opacity: 0; transform: translateY(18px); transition: opacity .5s ease, transform .5s ease; }
.reveal.visible { opacity: 1; transform: none; }
.reveal-delay-1 { transition-delay: .1s; }
.reveal-delay-2 { transition-delay: .2s; }

/* ── Header ──────────────────────────────────────── */
.site-header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(247,245,240,.94);
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--hairline);
  transition: box-shadow .2s;
}
.site-header.scrolled { box-shadow: 0 2px 16px rgba(22,36,59,.08); }

.header-inner { display: flex; align-items: center; justify-content: space-between; height: 68px; }

.brand { display: flex; align-items: center; gap: 10px; color: var(--ink); }
.brand-mark { font-family: var(--mono); font-size: 0.76rem; letter-spacing: 0.06em; background: var(--ink); color: var(--cream); padding: 5px 8px; border-radius: 2px; font-weight: 500; }
.brand-name { font-family: var(--serif); font-weight: 600; font-size: 1.08rem; color: var(--ink); }

.main-nav { display: flex; align-items: center; gap: 32px; }
.main-nav a { color: var(--ink); font-size: 0.92rem; font-weight: 500; transition: color .15s; }
.main-nav a:hover { color: var(--copper-deep); }
.nav-back { display: flex; align-items: center; gap: 6px; color: var(--slate) !important; font-size: 0.88rem !important; }
.nav-back:hover { color: var(--ink) !important; }
.nav-back::before { content: '←'; }

/* ── Page layout ─────────────────────────────────── */
.contact-page { padding: 80px 0 120px; }

.contact-page-inner {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 80px;
  align-items: start;
}

/* ── Left col ────────────────────────────────────── */
.contact-info > * + * { margin-top: 20px; }

.contact-info h1 { margin-top: 8px; }

.contact-lede {
  font-size: 1.05rem;
  line-height: 1.75;
  max-width: 400px;
}

.contact-direct {
  margin-top: 44px;
  border-top: 1px solid var(--hairline);
  padding-top: 32px;
  display: grid;
  gap: 24px;
}

.contact-direct-item { display: flex; flex-direction: column; gap: 5px; }

.contact-direct-label {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--copper-deep);
}

.contact-direct-item a {
  font-family: var(--serif);
  font-size: 1.15rem;
  color: var(--ink);
  transition: color .15s;
}
.contact-direct-item a:hover { color: var(--copper-deep); }

.contact-direct-item p {
  font-size: 0.9rem;
  color: var(--slate-lt);
}

.social-row {
  margin-top: 36px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.social-pill {
  display: inline-flex; align-items: center; gap: 7px;
  color: var(--ink); font-family: var(--mono); font-size: 0.78rem;
  letter-spacing: 0.04em; padding: 8px 14px;
  border: 1.5px solid var(--hairline); border-radius: var(--radius);
  transition: color .15s, border-color .15s, background .15s;
}
.social-pill:hover { color: var(--copper-deep); border-color: var(--copper); background: rgba(181,119,60,.05); }
.social-pill svg { width: 13px; height: 13px; fill: currentColor; flex-shrink: 0; }

/* ── Form ────────────────────────────────────────── */
.contact-form-wrap {
  background: var(--white);
  border: 1px solid var(--hairline);
  border-radius: 6px;
  padding: 44px;
  box-shadow: 0 4px 24px rgba(22,36,59,.06);
}

.contact-form-wrap h2 { margin-bottom: 8px; }
.contact-form-wrap > p { font-size: 0.93rem; margin-bottom: 32px; }

.form-grid { display: grid; gap: 22px; }

.form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

.field { display: grid; gap: 7px; }

.field label {
  font-family: var(--mono);
  font-size: 0.74rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--slate);
  display: flex;
  align-items: center;
  gap: 5px;
}

.required-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--copper);
  display: inline-block;
  flex-shrink: 0;
}

.field input,
.field textarea,
.field select {
  font-family: var(--sans);
  font-size: 0.97rem;
  color: var(--ink);
  background: var(--cream);
  border: 1.5px solid var(--hairline);
  border-radius: var(--radius);
  padding: 13px 15px;
  width: 100%;
  transition: border-color .15s, box-shadow .15s;
}

.field input::placeholder,
.field textarea::placeholder { color: var(--slate-lt); }

.field input:focus,
.field textarea:focus,
.field select:focus {
  outline: none;
  border-color: var(--copper);
  box-shadow: 0 0 0 3px rgba(181,119,60,.12);
}

.field input.error,
.field textarea.error { border-color: #e53e3e; box-shadow: 0 0 0 3px rgba(229,62,62,.1); }

.field textarea { resize: vertical; min-height: 130px; line-height: 1.6; }

.field-note {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--slate-lt);
  margin-top: 2px;
}

.form-required-note {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--slate-lt);
  margin-bottom: 6px;
}

.form-submit-row { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }

.btn-submit {
  background: var(--ink);
  color: var(--cream);
  border: none;
  padding: 15px 36px;
  border-radius: var(--radius);
  font-family: var(--sans);
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: background .15s, transform .15s;
  display: flex; align-items: center; gap: 8px;
}
.btn-submit:hover { background: var(--copper-deep); transform: translateY(-1px); }
.btn-submit:disabled { background: var(--slate-lt); cursor: not-allowed; transform: none; }

.form-success {
  display: none;
  background: #F0FAF4;
  border: 1.5px solid #68D391;
  border-radius: var(--radius);
  padding: 18px 20px;
  margin-top: 20px;
}
.form-success p { color: #276749; font-size: 0.95rem; font-weight: 500; }

.form-error-msg {
  display: none;
  background: #FFF5F5;
  border: 1.5px solid #FC8181;
  border-radius: var(--radius);
  padding: 14px 18px;
  margin-top: 16px;
}
.form-error-msg p { color: #9B2C2C; font-size: 0.9rem; }

.field-error {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: #e53e3e;
  display: none;
  margin-top: 2px;
}
.field-error.visible { display: block; }

/* ── Footer ──────────────────────────────────────── */
.site-footer {
  background: var(--ink);
  border-top: 1px solid rgba(255,255,255,.08);
  padding: 32px 0;
}

.footer-inner {
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 14px;
}

.footer-inner .brand-mark { background: var(--cream); color: var(--ink); }
.footer-inner .brand-name { color: var(--cream); }
.footer-inner p { color: rgba(255,255,255,.35); font-size: 0.82rem; }

/* ── Responsive ──────────────────────────────────── */
@media (max-width: 900px) {
  .contact-page-inner { grid-template-columns: 1fr; gap: 48px; }
  .contact-form-wrap { padding: 28px; }
}

@media (max-width: 560px) {
  .form-row-2 { grid-template-columns: 1fr; }
  .contact-page { padding: 56px 0 80px; }
}
</style>
</head>
<body>

<!-- ── HEADER ──────────────────────────────────── -->
<header class="site-header" id="site-header">
  <div class="wrap header-inner">
    <a href="index.html" class="brand">
      <span class="brand-mark">MWS</span>
      <span class="brand-name">McGee Web Solutions</span>
    </a>
    <nav class="main-nav">
      <a href="index.html" class="nav-back">Back to home</a>
    </nav>
  </div>
</header>

<!-- ── CONTACT PAGE ────────────────────────────── -->
<main>
  <section class="contact-page">
    <div class="wrap contact-page-inner">

      <!-- Left: info -->
      <div class="contact-info reveal visible">
        <span class="eyebrow">Get in touch</span>
        <h1>Let's talk about your business.</h1>
        <p class="contact-lede">Fill in the form and we'll get back to you within one business day. Prefer a call? Reach us directly below.</p>

        <div class="contact-direct">
          <div class="contact-direct-item">
            <span class="contact-direct-label">Email</span>
            <a href="mailto:d.mcgee.web@gmail.com">d.mcgee.web@gmail.com</a>
            <p>For project enquiries and quotes</p>
          </div>
          <div class="contact-direct-item">
            <span class="contact-direct-label">Based in</span>
            <span style="font-family:var(--serif);font-size:1.15rem;color:var(--ink)">Ireland</span>
            <p>Working with clients across Ireland, the UK, and beyond</p>
          </div>
          <div class="contact-direct-item">
